# ── LLM providers ──────────────────────────────────────────────────────────
# At least one key is required. Set both to use either provider via the API.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Poppler (pdf2image) — Windows only ─────────────────────────────────────
# Skip if Poppler bin/ folder is already on system PATH.
# Example: C:\Users\you\Downloads\poppler-windows-25.12.0-0\Library\bin
POPPLER_PATH=

# ── Tesseract OCR — Windows only ───────────────────────────────────────────
# Skip if Tesseract is already on system PATH.
# Example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
